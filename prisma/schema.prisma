generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH MODELS (Better Auth) ====================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  subscription  Subscription?
  credits       Credits?
  usageLogs     UsageLog[]
  history       ToolHistory[]
  favorites     Favorite[]
  notifications Notification[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  providerId            String
  accountId             String
  accessToken           String?   @db.Text
  refreshToken          String?   @db.Text
  idToken               String?   @db.Text
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}

// ==================== BILLING / SUBSCRIPTION ====================

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique
  plan                 Plan     @default(FREE)
  status               SubStatus @default(ACTIVE)
  billingCycle         BillingCycle @default(MONTHLY)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  currentPeriodEnd     DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Credits {
  id        String   @id @default(cuid())
  userId    String   @unique
  balance   Int      @default(50)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("credits")
}

// ==================== AI TOOLS USAGE ====================

model UsageLog {
  id        String   @id @default(cuid())
  userId    String
  toolSlug  String
  tokensUsed Int     @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolSlug])
  @@map("usage_logs")
}

model ToolHistory {
  id        String   @id @default(cuid())
  userId    String
  toolSlug  String
  input     String   @db.Text
  output    String   @db.Text
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolSlug])
  @@map("tool_history")
}

model Favorite {
  id       String @id @default(cuid())
  userId   String
  toolSlug String
  createdAt DateTime @default(now())

  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, toolSlug])
  @@map("favorites")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}